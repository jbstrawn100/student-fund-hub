{
  "name": "iterator-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "db:migrate": "set -e; DB_URL=${DATABASE_URL:-postgresql://${PGUSER:-supabase_admin}:${PGPASSWORD:-postgres}@${PGHOST:-localhost}:${PGPORT:-54322}/${PGDATABASE:-postgres}}; for f in supabase/migrations/*.sql; do echo \"Running $f\"; psql \"$DB_URL\" -v ON_ERROR_STOP=1 -f \"$f\"; done",
    "db:seed": "node scripts/import-from-csv.mjs",
    "db:create-admin": "node scripts/create-admin-user.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run db:create-admin"
  },
